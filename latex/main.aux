\@writefile{toc}{\contentsline {section}{\numberline {7.2}ROI with bootstrap intervals}{24}{section.7.2}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{What the simulation is and is not.}{24}{section.7.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7.1}{\ignorespaces Simulated flat-stake ROI of the $s = r$ upset policy on the Vegas-aligned test slice, using \emph  {de-vigged} (not tradable) implied prices. $P(\text  {ROI}\le 0)$ is the empirical probability of a non-positive resample ROI from $2{,}000$ paired bootstrap draws. $\theta = 0.15$ is the headline threshold but was selected post-hoc as the smallest grid value at which the CI excludes zero; all four rows are reported so the reader can see the threshold sensitivity.}}{25}{table.7.1}\protected@file@percent }
\newlabel{tab:roi}{{7.1}{25}{Simulated flat-stake ROI of the $s = r$ upset policy on the Vegas-aligned test slice, using \emph {de-vigged} (not tradable) implied prices. $P(\text {ROI}\le 0)$ is the empirical probability of a non-positive resample ROI from $2{,}000$ paired bootstrap draws. $\theta = 0.15$ is the headline threshold but was selected post-hoc as the smallest grid value at which the CI excludes zero; all four rows are reported so the reader can see the threshold sensitivity}{table.7.1}{}}
