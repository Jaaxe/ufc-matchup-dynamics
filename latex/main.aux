\@writefile{toc}{\contentsline {paragraph}{Cross-cluster style mismatches (Dillashaw/Barao).}{26}{table.8.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {8.1}{\ignorespaces Five canonical UFC upsets, listed by event. $p_\text  {vegas}$ and $p_\text  {model}$ are reported on the eventual winner where available; $r = p_\text  {model} - p_\text  {vegas}$ is the winner-oriented residual that Chapter~\ref {ch:upset}'s threshold policy would have seen. Each $p_\text  {model}$ is fit by a symmetry-augmented HGB on all fights strictly preceding the event date. A residual of $\ge 0.15$ would have triggered a bet under the $\theta = 0.15$ policy of Chapter~\ref {ch:upset}; this is the same exploratory threshold flagged in Section~\ref {sec:repro}.}}{27}{table.8.1}\protected@file@percent }
\newlabel{tab:cases}{{8.1}{27}{Five canonical UFC upsets, listed by event. $p_\text {vegas}$ and $p_\text {model}$ are reported on the eventual winner where available; $r = p_\text {model} - p_\text {vegas}$ is the winner-oriented residual that Chapter~\ref {ch:upset}'s threshold policy would have seen. Each $p_\text {model}$ is fit by a symmetry-augmented HGB on all fights strictly preceding the event date. A residual of $\ge 0.15$ would have triggered a bet under the $\theta = 0.15$ policy of Chapter~\ref {ch:upset}; this is the same exploratory threshold flagged in Section~\ref {sec:repro}}{table.8.1}{}}
