\@writefile{lot}{\contentsline {table}{\numberline {5.2}{\ignorespaces Win-loss metrics on the Vegas-aligned held-out test subset ($n = 1{,}129$); lower is better for Brier and log loss. ``Stack'' is the isotonic-stacked LR$+$HGB$+$RF ensemble without Vegas, fit on the Vegas-aligned training rows; ``Stack+Vegas'' is the same stack with $p_{\text  {vegas},A}$ added as a fourth meta-input. Paired bootstrap (Stack+Vegas $-$ Vegas), $2{,}000$ resamples.}}{18}{table.5.2}\protected@file@percent }
\newlabel{tab:vegas-compare}{{5.2}{18}{Win-loss metrics on the Vegas-aligned held-out test subset ($n = 1{,}129$); lower is better for Brier and log loss. ``Stack'' is the isotonic-stacked LR$+$HGB$+$RF ensemble without Vegas, fit on the Vegas-aligned training rows; ``Stack+Vegas'' is the same stack with $p_{\text {vegas},A}$ added as a fourth meta-input. Paired bootstrap (Stack+Vegas $-$ Vegas), $2{,}000$ resamples}{table.5.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.1}{\ignorespaces Left: reliability curves on the Vegas-aligned test subset for Vegas, HGB (non-Vegas features), logistic regression (full), and the stack with Vegas as a feature. Right: Brier, log loss, and ECE. \texttt  {Stack+Vegas} tracks the diagonal most closely and attains the lowest Brier, log loss, and ECE. Source: notebook~20.}}{19}{figure.5.1}\protected@file@percent }
\newlabel{fig:reliability-vegas}{{5.1}{19}{Left: reliability curves on the Vegas-aligned test subset for Vegas, HGB (non-Vegas features), logistic regression (full), and the stack with Vegas as a feature. Right: Brier, log loss, and ECE. \texttt {Stack+Vegas} tracks the diagonal most closely and attains the lowest Brier, log loss, and ECE. Source: notebook~20}{figure.5.1}{}}
